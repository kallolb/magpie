# Magpie Configuration
# Copy this to .env and customize

# ── Storage ────────────────────────────────────────────
# Local path for video storage (used by docker-compose.yml)
STORAGE_PATH=./storage

# ── Security ───────────────────────────────────────────
# API key for authenticating requests (change this!)
API_KEY=changeme

# ── Download Settings ──────────────────────────────────
DEFAULT_QUALITY=1080
MAX_CONCURRENT_DOWNLOADS=3

# ── NAS Settings (used by docker-compose.nas.yml) ─────
# NAS_IP=192.168.1.100
# NAS_PATH=/volume1/videos

# ── Chat Bot Tokens (optional) ────────────────────────
# TELEGRAM_BOT_TOKEN=
# DISCORD_BOT_TOKEN=
# SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET=
